# Telegram Bot
BOT_TOKEN=your_bot_token_from_botfather

# Telegram API (для Telethon — получить на https://my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# Админы бота (chat_id через запятую)
ADMIN_IDS=123456789,987654321

# Пути
DATA_PATH=./data

# Ollama (локально на маке)
OLLAMA_URL=http://localhost:11434
DEFAULT_MODEL=saiga_llama3_8b

# Google Service Account (для MCP и Google API)
# Файл хранится ВНЕ репозитория: ~/.config/intelbot/google_service_account.json
GOOGLE_SERVICE_ACCOUNT_PATH=~/.config/intelbot/google_service_account.json
